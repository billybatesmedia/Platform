# Default: ignore everything at repo root.
/*

# Keep repo meta and standards files.
!/.gitignore
!/.editorconfig
!/README.md

# Keep custom scripts/services at root.
!/ChangeSiteDomainService.js
!/SearchReplacerWPConfigDomain.js

# Keep project docs subtree, then narrow to maintained docs.
!/Docs/
/Docs/*
!/Docs/template-system/
/Docs/template-system/*
!/Docs/template-system/README.md
!/Docs/template-system/V1-DEFINITION-OF-DONE.md
!/Docs/template-system/OPERATOR-CHECKLIST.md
!/Docs/template-system/SERVICE-NAMING-CUT-LIST.md
!/Docs/template-system/SITE-DOCS-RUNBOOK.md
!/Docs/template-system/sample-payloads/
!/Docs/template-system/sample-payloads/**
!/Docs/template-system/evidence/
/Docs/template-system/evidence/*
!/Docs/template-system/evidence/README.md

# Ignore generated artifact trees.
/Docs/template-system/backups/
/Docs/template-system/release-packets/

# Keep only the custom theme source from wp-content.
!/wp-content/
/wp-content/*
!/wp-content/themes/
/wp-content/themes/*
!/wp-content/themes/lithia-web-service-theme/
!/wp-content/themes/lithia-web-service-theme/**

# Ignore packaged theme zips and common local noise.
/wp-content/themes/*.zip
*.zip
*.crdownload
.DS_Store
